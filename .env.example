# OpenRouter (하나의 키로 여러 LLM provider 사용 가능)
OPENROUTER_API_KEY=sk-or-...

# LiteLLM proxy 서버 설정
# LiteLLM 자체 API 키는 없음 — 아래 provider 키들을 LiteLLM 서버에 설정해야 함
# LITELLM_API_KEY는 프록시에 인증을 걸었을 때만 필요 (선택사항)
LITELLM_API_KEY=
LITELLM_BASE_URL=http://localhost:4000

# 실제 LLM provider 키 (LiteLLM 또는 직접 호출 시 필요)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Portkey AI Gateway (upstream provider 키는 OPENAI_API_KEY 등을 그대로 사용)
PORTKEY_API_KEY=

# Google Gemini API
GOOGLE_API_KEY=

# Cloudflare AI Gateway (인증을 켠 경우만 필요)
CF_AIG_TOKEN=
